# Server-side runtime values only. Do not commit live secrets.
APP_ENV=development
PORT=3000
DATABASE_URL=postgres://freshful:freshful@localhost:5432/freshful
APP_SESSION_SECRET=replace-with-a-long-random-session-secret
APP_SESSION_TTL_SECONDS=2592000
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
ANTHROPIC_API_KEY=replace-with-local-dev-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_MODEL_HAIKU=claude-3-5-haiku-latest
ANTHROPIC_MODEL_SONNET=claude-3-7-sonnet-latest
ANTHROPIC_REQUEST_TIMEOUT_MS=20000
AI_MAX_PROMPT_CHARS=16000
AI_MAX_OUTPUT_TOKENS=1200
AI_MAX_TRANSCRIPT_MESSAGES=24
AI_ROUTE_SONNET_MESSAGE_THRESHOLD=10
AI_ROUTE_SONNET_CHAR_THRESHOLD=5000
FRESHFUL_BASE_URL=https://www.freshful.ro
FRESHFUL_SEARCH_PATH=/api/v2/shop/search
FRESHFUL_REQUEST_TIMEOUT_MS=10000