{
  "name": "copilot-orchestrator-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable VS Code and GitHub Copilot boilerplate for DESCRIPTION.md-first app delivery workflows.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "tsx --test tests/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "env:bootstrap": "node scripts/bootstrap-env.mjs",
    "env:check": "node scripts/bootstrap-env.mjs --check",
    "start": "npm run env:bootstrap && node scripts/start-dev.mjs",
    "dev": "npm run start"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  },
  "engines": {
    "node": ">=18"
  }
}
