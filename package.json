{
  "name": "copilot-orchestrator-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable VS Code and GitHub Copilot boilerplate for DESCRIPTION.md-first app delivery workflows.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "plan:next": "node scripts/find-plan-item.mjs next",
    "plan:last": "node scripts/find-plan-item.mjs last",
    "plan:summary": "node scripts/find-plan-item.mjs summary",
    "progress:update": "node scripts/update-progress.mjs",
    "changes:list": "node scripts/collect-changed-files.mjs",
    "changes:check": "node scripts/check-changed-files.mjs",
    "commit:draft": "node scripts/generate-commit-message.mjs",
    "hooks:log": "node scripts/log-hook-event.mjs",
    "hooks:validate": "node scripts/validate-workspace.mjs",
    "db:generate": "npm run db:generate --workspace @freshful/api",
    "db:migrate": "npm run db:migrate --workspace @freshful/api",
    "lint": "eslint . --ext .ts,.tsx,.mjs,.cjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:backend": "tsx --test tests/*.test.ts",
    "test:persistence": "tsx --test tests/api-persistence.test.ts",
    "test:mobile:critical": "npm run test:critical --workspace @freshful/mobile",
    "test": "npm run test:backend && npm run test:mobile:critical",
    "typecheck:mobile": "npm run typecheck --workspace @freshful/mobile",
    "test:mobile": "npm run test --workspace @freshful/mobile",
    "android:smoke:mobile": "npm run android:smoke --workspace @freshful/mobile",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "env:bootstrap": "node scripts/bootstrap-env.mjs",
    "env:check": "node scripts/bootstrap-env.mjs --check",
    "start": "npm run env:bootstrap && node scripts/start-dev.mjs",
    "dev": "npm run start"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  },
  "engines": {
    "node": ">=18"
  }
}